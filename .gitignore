# Môi trường ảo Python
.venv/
env/
venv/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Dữ liệu sinh ra trong quá trình chạy (Rác, Cache, Model 3D)
data/cache/*
data/feedback/*
data/outputs/*
data/uploads/*
!data/cache/.gitkeep
!data/feedback/.gitkeep
!data/outputs/.gitkeep
!data/uploads/.gitkeep

# Checkpoint weights của AI Model (File quá nặng không nên push lên Git)
models/*.pth
models/*.ckpt
*.ckpt
*.pth

# Các thư mục linh tinh của OS và IDE
.DS_Store
.vscode/
.idea/
*.swp
*.swo
